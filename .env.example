# ---- Server ----
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed origins (storefront + admin panel)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ---- Database (MongoDB on your VPS) ----
MONGODB_URI=mongodb://127.0.0.1:27017/pawar_online

# ---- Auth ----
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ---- File storage / CDN ----
# Where uploaded files are written on the VPS disk
UPLOAD_DIR=./uploads
# Public base URL your CDN/Nginx serves the uploads from.
# In dev this can point back at the API itself (it also serves /uploads).
# IMPORTANT: the host:port here must match where the API actually runs
# (PORT above), or your CDN domain in production.
CDN_BASE_URL=http://localhost:4000/uploads

# ---- Seed admin (used by `npm run seed`) ----
SEED_ADMIN_EMAIL=admin@pawaronline.in
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Administrator
